rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Product images: public read (customers must see images),
    // only signed-in users can upload (tighten to admin-only via a
    // Firestore lookup + custom claims for full production security).
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 // max 5MB
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
